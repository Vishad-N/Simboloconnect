# =========================================================================
# Production Deployment Environment Configuration Template
# =========================================================================
# Optimized for secure, production-grade deployments under HTTPS.

# -------------------------------------------------------------------------
# Security & Process Controls
# -------------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# Strict CORS allowed origins. Delimit multiple domains by comma.
CORS_ALLOWED_ORIGINS=https://panel.yourdomain.com,https://admin.yourdomain.com

# HTTP Cookie session parameters
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
SESSION_TIMEOUT_MS=86400000

# JWT and payload encryption
JWT_SECRET=your_jwt_signature_secret_key_minimum_32_characters
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# -------------------------------------------------------------------------
# High-Availability Database Connection
# -------------------------------------------------------------------------
# PostgreSQL connection with connection pooling pool size enabled (pgBouncer / direct)
DATABASE_URL="postgresql://db_user:db_password@postgres_host:5432/whatsapp_panel_db?schema=public&sslmode=verify-full&connection_limit=20&pool_timeout=10"
DIRECT_DATABASE_URL="postgresql://db_user:db_password@postgres_host:5432/whatsapp_panel_db?schema=public&sslmode=verify-full"

# Redis caching and queue configuration
REDIS_URL="redis://:redis_password@redis_host:6379/0"

# -------------------------------------------------------------------------
# System Core Integrations
# -------------------------------------------------------------------------
META_API_VERSION=v20.0
WEBHOOK_VERIFY_TOKEN=your_production_verify_token
DEFAULT_META_APP_ID=your_production_meta_app_id

# -------------------------------------------------------------------------
# Production Logging & Auditing
# -------------------------------------------------------------------------
# Logging verbosity: info | warn | error | debug
LOG_LEVEL=info
ENABLE_AUDIT_LOGGING=true

# -------------------------------------------------------------------------
# Email & Alerts
# -------------------------------------------------------------------------
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=465
SMTP_USER=postmaster@yourdomain.com
SMTP_PASS=your_smtp_smtp_password_here
SMTP_FROM=noreply@yourdomain.com
SMTP_SENDER_NAME="WaDesk Live"
SUPPORT_EMAIL=support@yourdomain.com

# -------------------------------------------------------------------------
# Payment & Gateways
# -------------------------------------------------------------------------
PAYMENT_GATEWAY=stripe
PAYMENT_GATEWAY_KEY=stripe_key_xxxxxxxxxxxxxxxxxxxxxxxx
PAYMENT_GATEWAY_SECRET=stripe_secret_xxxxxxxxxxxxxxxxxxxxxxxx

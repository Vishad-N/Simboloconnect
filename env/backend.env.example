# =========================================================================
# Backend Environment Configuration Template
# =========================================================================
# Copy this file to '.env' inside the backend folder and fill in your keys.
# Do not share your live production credentials.

# -------------------------------------------------------------------------
# Server Mappings
# -------------------------------------------------------------------------
PORT=3000
NODE_ENV=production
# The backend public-facing domain URL (used for callbacks and webhooks)
PUBLIC_URL=https://api.yourdomain.com
# The user frontend url (for redirection and email invite paths)
FRONTEND_URL=https://panel.yourdomain.com

# -------------------------------------------------------------------------
# Cryptography & Session Tokens
# -------------------------------------------------------------------------
# Secret key used to sign JSON Web Tokens (JWT) for authentication
JWT_SECRET=your_jwt_signature_secret_key_minimum_32_characters
# 32-byte encryption key (in hex format) to encrypt sensitive DB credentials like Meta tokens
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# -------------------------------------------------------------------------
# Database Connectivity (Prisma)
# -------------------------------------------------------------------------
# PostgreSQL Connection URLs
DATABASE_URL="postgresql://db_user:db_password@postgres_host:5432/whatsapp_panel_db?schema=public&sslmode=prefer"
# Required for prisma migration runners executing direct DDL statements
DIRECT_DATABASE_URL="postgresql://db_user:db_password@postgres_host:5432/whatsapp_panel_db?schema=public&sslmode=prefer"

# Redis cache and queue server connection URL
REDIS_URL="redis://:redis_password@redis_host:6379/0"

# -------------------------------------------------------------------------
# Meta WhatsApp API Configurations (System Settings Fallbacks)
# -------------------------------------------------------------------------
# The version of Graph API to use (e.g. v20.0)
META_API_VERSION=v20.0
# Verification token requested when register Meta Webhooks in Developer Panel
WEBHOOK_VERIFY_TOKEN=your_custom_webhook_verify_token
# Default Meta App ID utilized when workspace-specific credentials are missing
DEFAULT_META_APP_ID=your_meta_app_id

# -------------------------------------------------------------------------
# SMTP Outbound Email Settings
# -------------------------------------------------------------------------
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@yourdomain.com
SMTP_PASS=your_smtp_smtp_password_here
SMTP_FROM=noreply@yourdomain.com
SMTP_SENDER_NAME="WaDesk Notifications"
SUPPORT_EMAIL=support@yourdomain.com

# -------------------------------------------------------------------------
# AI Agent & OpenRouter Settings
# -------------------------------------------------------------------------
# Platform application name (used in OpenRouter X-Title header and platform branding)
APP_NAME=WaDesk
# API credential key for LLM dispatches via OpenRouter
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The referrer header required by OpenRouter API checks
OPENROUTER_REFERRER=https://yourdomain.com
DEFAULT_AI_PROVIDER=openrouter
DEFAULT_AI_MODEL=gpt-4o-mini

# -------------------------------------------------------------------------
# Voice Providers (Twilio, Vapi, Retell)
# -------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

VAPI_API_KEY=vapi-api-key-here
RETELL_API_KEY=retell-api-key-here

# -------------------------------------------------------------------------
# Payment Gateway Settings (Balance Credit Top-ups)
# -------------------------------------------------------------------------
# Choice: razorpay | stripe
PAYMENT_GATEWAY=stripe
PAYMENT_GATEWAY_KEY=stripe_key_xxxxxxxxxxxxxxxxxxxxxxxx
PAYMENT_GATEWAY_SECRET=stripe_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------------------------
# Onboarding & AI Voice Calling
# -------------------------------------------------------------------------
# Enable AI voice calling for new user onboarding (true/false)
ENABLE_AI_VOICE_CALLING=false
# Your WhatsApp number to receive new user registration notifications
# Format: country_code + number without + (e.g. 919876543210 for India)
# Leave blank to disable registration notifications
MASTER_ONBOARDING_PHONE=

# -------------------------------------------------------------------------
# Licensing & Activation (Architecture Hook)
# -------------------------------------------------------------------------
# Cryptographic key to unlock the self-hosted distribution panel
LICENSE_KEY=LIC-XXXX-YYYY-ZZZZ-WWWW

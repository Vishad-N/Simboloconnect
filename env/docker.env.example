# =========================================================================
# Docker Stack Environment Configuration Template
# =========================================================================
# This file is utilized by docker-compose to pass env variables to all services.
# Copy this to '.env' at the root of the deployment directory.

# -------------------------------------------------------------------------
# Stack Global Mappings
# -------------------------------------------------------------------------
NODE_ENV=production
JWT_SECRET=your_jwt_signature_secret_key_minimum_32_characters
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Database credentials (internal Docker service mappings)
POSTGRES_USER=db_user
POSTGRES_PASSWORD=db_password
POSTGRES_DB=whatsapp_panel_db
REDIS_PASSWORD=redis_password

# Hostnames & Subdomains (Mapped to Reverse Proxy SSL Setup)
DOMAIN_BACKEND=api.yourdomain.com
DOMAIN_USER=panel.yourdomain.com
DOMAIN_ADMIN=admin.yourdomain.com

# -------------------------------------------------------------------------
# Backend Service Variables
# -------------------------------------------------------------------------
BACKEND_PORT=3000
DATABASE_URL=postgresql://db_user:db_password@postgres:5432/whatsapp_panel_db?schema=public
DIRECT_DATABASE_URL=postgresql://db_user:db_password@postgres:5432/whatsapp_panel_db?schema=public
REDIS_URL=redis://:redis_password@redis:6379/0

# Meta Cloud API
META_API_VERSION=v20.0
WEBHOOK_VERIFY_TOKEN=your_custom_webhook_verify_token
DEFAULT_META_APP_ID=your_meta_app_id_here

# Outbound Mail (SMTP)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@yourdomain.com
SMTP_PASS=your_smtp_smtp_password_here
SMTP_FROM=noreply@yourdomain.com
SMTP_SENDER_NAME="WaDesk Notifications"
SUPPORT_EMAIL=support@yourdomain.com

# AI & Voice Providers
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_REFERRER=https://yourdomain.com
DEFAULT_AI_PROVIDER=openrouter
DEFAULT_AI_MODEL=gpt-4o-mini
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPI_API_KEY=vapi-api-key-here
RETELL_API_KEY=retell-api-key-here

# Payment Gateway Settings
PAYMENT_GATEWAY=stripe
PAYMENT_GATEWAY_KEY=stripe_key_xxxxxxxxxxxxxxxxxxxxxxxx
PAYMENT_GATEWAY_SECRET=stripe_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------------------------
# Frontend Services Variables (Build Arguments & Runtime Parameters)
# -------------------------------------------------------------------------
VITE_API_URL=https://api.yourdomain.com
VITE_BRAND_NAME=WaDesk
VITE_SUPPORT_EMAIL=support@yourdomain.com
VITE_LOGO_URL=/logo.svg
VITE_FAVICON_URL=/favicon.ico
VITE_FOOTER_COPYRIGHT="© 2026 WaDesk. All rights reserved."
VITE_META_APP_ID=your_meta_app_id_here
VITE_META_JS_SDK_VERSION=v20.0

# =========================================================================
# Admin Frontend Environment Configuration Template
# =========================================================================
# Copy this file to '.env' inside the frontend-admin folder and rebuild.

# The public facing URL of your backend API.
# Note: Ensure it has no trailing slash.
VITE_API_URL=https://api.yourdomain.com

# -------------------------------------------------------------------------
# Admin Brand Customization Settings
# -------------------------------------------------------------------------
# Customize the brand name shown in titles, menus, and text headers in Admin
VITE_BRAND_NAME="WaDesk Admin"

# Support email displayed to administrators
VITE_SUPPORT_EMAIL=support@yourdomain.com

# Full URL to your admin brand logo SVG/PNG (or relative public path like '/logo.svg')
VITE_LOGO_URL=/logo.svg

# Full URL to your admin favicon icon file (or relative public path like '/favicon.ico')
VITE_FAVICON_URL=/favicon.ico

# Footer copyright text displayed on the login page and dashboard footer
VITE_FOOTER_COPYRIGHT="© 2026 WaDesk. All rights reserved."

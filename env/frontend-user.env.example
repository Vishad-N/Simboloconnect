# =========================================================================
# User Frontend Environment Configuration Template
# =========================================================================
# Copy this file to '.env' inside the frontend-user folder and rebuild.

# The public facing URL of your backend API.
# Note: Ensure it has no trailing slash.
VITE_API_URL=https://api.yourdomain.com

# -------------------------------------------------------------------------
# Brand Customization settings
# -------------------------------------------------------------------------
# Customize the brand name shown in titles, menus, and text headers
VITE_BRAND_NAME=WaDesk

# Support email displayed to customers in user guides and dashboards
VITE_SUPPORT_EMAIL=support@yourdomain.com

# Full URL to your brand logo SVG/PNG (or relative public path like '/logo.svg')
VITE_LOGO_URL=/logo.svg

# Full URL to your favicon icon file (or relative public path like '/favicon.ico')
VITE_FAVICON_URL=/favicon.ico

# Footer copyright text displayed on the login page and dashboard footer
VITE_FOOTER_COPYRIGHT="© 2026 WaDesk. All rights reserved."

# -------------------------------------------------------------------------
# Meta/Facebook Embedded Signup Credentials
# -------------------------------------------------------------------------
# The Meta App ID connected to your WhatsApp Business Embedded Signup flow
VITE_META_APP_ID=your_meta_app_id_here

# Meta Graph API version used by the javascript SDK (default: v20.0)
VITE_META_JS_SDK_VERSION=v20.0
